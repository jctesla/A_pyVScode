:root { font-size: 14px; }

body, html { margin: 0px; padding: 0px; }

html { box-sizing: border-box; width: 100%; height: 100%; scroll-padding-to=
p: 82px; }

html :where(img[class*=3D"wp-image-"]) { margin: 10px 0px; }

*, ::after, ::before { box-sizing: inherit; }

body { font-family: Roboto, Arial, sans-serif; font-style: normal; font-wei=
ght: 400; font-size: 1rem; line-height: 1.66; color: rgb(35, 57, 93); backg=
round-color: rgb(246, 247, 249); overflow-x: hidden; }

.h1, .h2, .h3, .h4, .h5, .h6, h1, h2, h3, h4, h5, h6 { font-weight: 400; li=
ne-height: 1.5; margin: 20px 0px; }

h1, h1.entry-title { font-weight: 600; font-size: 2.5rem; margin-top: 0px; =
letter-spacing: 0.02em; }

.h2, h2 { font-weight: 400; font-size: 1.9rem; margin-bottom: 24px; }

.h3, h3 { font-weight: 600; font-size: 1.5rem; }

.h4, h4 { font-size: 1.25rem; }

.h5, h5 { font-size: 1.15rem; }

.h6, h6 { font-size: 1rem; font-weight: 500; }

a { color: rgb(42, 96, 200); text-decoration: underline; }

a:hover { text-decoration: none; }

a.anchor { display: block; position: relative; top: -20px; visibility: hidd=
en; }

hr { width: 100%; margin-top: 10px; margin-bottom: 10px; border-top: 1px so=
lid rgb(204, 204, 204); }

p { margin: 0px 0px 15px; }

p:empty { display: none; }

pre { font-size: 1rem; line-height: 1.6; }

li { margin-bottom: 5px; }

li > p { margin: 0px; }

li > .well { margin: 5px 0px 0px; }

td { line-height: 1.6 !important; padding: 10px !important; }

tt { background-color: transparent; }

iframe { margin: 20px 0px; }

.vcenter { justify-content: center; }

